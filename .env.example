# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # usado só no servidor (webhook/admin)

# Asaas
ASAAS_ENV=sandbox                  # sandbox | production
ASAAS_API_KEY=$aact_...            # chave da API Asaas
ASAAS_WEBHOOK_TOKEN=um-token-secreto  # validado no header do webhook
ASAAS_BILLING=UNDEFINED            # forma padrão qdo NÃO usa cartão (UNDEFINED|BOLETO|PIX)

# Cobrança / cron
CRON_SECRET=um-secret-do-cron      # protege /api/cron/cobranca
DIAS_NEGATIVAR=30                  # dias de atraso p/ escalar negativação

# Análise de crédito (pluggável — ver src/lib/credito.ts)
CREDIT_PROVIDER=stub               # stub | bigdatacorp | idwall | serasa
CREDIT_MIN_SCORE=500               # nota mínima p/ aprovar
# CREDIT_API_TOKEN=...             # credencial do provider real
# CREDIT_API_ACCESS=...
